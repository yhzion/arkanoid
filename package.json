{
  "name": "arkanoid-web",
  "version": "0.1.0",
  "description": "NES Arkanoid reference-accurate web implementation (clean-room).",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "validate:levels": "tsx tools/validateLevels.ts",
    "generate:levels": "tsx tools/generateLevels.ts",
    "preview:level": "tsx tools/renderLevelPreview.ts",
    "compare:level": "tsx tools/compareReferenceImage.ts"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4",
    "tsx": "^4.19.2",
    "@types/node": "^22.9.0",
    "jsdom": "^25.0.1"
  }
}
